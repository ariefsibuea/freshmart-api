SERVER_PORT=8080
SERVER_SHUTDOWN_TIMEOUT=5s
SERVER_READ_TIMEOUT=5s
SERVER_WRITE_TIMEOUT=10s
SERVER_IDLE_TIMEOUT=60s

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=fm-user
MYSQL_PASSWORD=fm-pass
MYSQL_ROOT_PASSWORD=root-fm-pass
MYSQL_DATABASE=freshmart_api
MYSQL_MAX_OPEN_CONNS=10
MYSQL_MIN_OPEN_CONNS=2
MYSQL_MAX_CONN_LIFETIME=1h
MYSQL_MAX_CONN_IDLE_TIME=30m

DEFAULT_CACHE_TTL=300s
REDIS_HOST=redis
REDIS_PORT=6379
